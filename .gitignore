# --- COUCHE 1 : RUST (COMPILATION AOT) ---
# Empêche l'indexation de Gigaoctets de binaires spécifiques à votre CPU
/target/

# --- COUCHE 2 : INFRASTRUCTURE & SECRETS ---
# Ne jamais versionner les accès à PostgreSQL
.env
.env.local
.env.*.local

# Fichiers de log de la base de données ou du runtime
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- COUCHE 3 : ENVIRONNEMENT LINUX (DEBIAN/UBUNTU) ---
# Fichiers temporaires de l'éditeur ou du système
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Vim
.*.swp
.*.swo

# --- COUCHE 4 : SPECIFIQUE POSTGRESQL ---
# Si vous faites des dumps de sauvegarde en local
*.sql.gz
*.sql.bak
